FROM rust:1.82-bookworm

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3.11-dev \
    && rm -rf /var/lib/apt/lists/*

COPY mcu_rust /workspace/mcu_rust
COPY docker/mcu_entrypoint.sh /usr/local/bin/mcu_entrypoint.sh

RUN chmod +x /usr/local/bin/mcu_entrypoint.sh \
    && cd /workspace/mcu_rust \
    && cargo build --release --bin real_tensor --bin real_nonlinear

WORKDIR /workspace/mcu_rust

ENTRYPOINT ["/usr/local/bin/mcu_entrypoint.sh"]
